# Google Cloud Project Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
GCP_SA_KEY=your-service-account-key-in-json-format

# Cloud Run Configuration
CLOUD_RUN_SERVICE_NAME=adcp-server
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=10
CLOUD_RUN_CPU=1
CLOUD_RUN_MEMORY=512Mi

# Cloud SQL Configuration
CLOUD_SQL_INSTANCE_NAME=adcp-postgres
CLOUD_SQL_DATABASE_NAME=adcp
CLOUD_SQL_USER=adcp_user
CLOUD_SQL_PASSWORD=your-secure-password-here

# AdCP Server Configuration
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE

# Optional: Custom Domain
CUSTOM_DOMAIN=

# Optional: Secrets (use Secret Manager in production)
# API_KEY=your-api-key
# JWT_SECRET=your-jwt-secret
